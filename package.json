{
  "name": "all4all",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon src/backend/start.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "start-server-and-test dev http://localhost:5173 'jest tests/ --watchAll=false'",
    "test:e2e:coverage": "npm run test:e2e && npx nyc report --reporter=html --report-dir=./coverage/selenium"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "jsdom": "^29.0.0",
    "nodemon": "^3.1.14",
    "selenium-webdriver": "^4.41.0",
    "start-server-and-test": "^2.1.5",
    "supertest": "^7.2.2",
    "vite": "^7.3.1",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
